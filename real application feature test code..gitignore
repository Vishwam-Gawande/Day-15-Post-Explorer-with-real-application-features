import json
import requests


url = "https://jsonplaceholder.typicode.com/posts"
response = requests.get(url)
posts = response.json()
saved_posts = []


def show_post():
    for post in posts[:10]:
        print(post["id"], "-", post["title"])


def search_post():
    keyword = input("Enetr Keyword: ")
    found = False

    for post in posts:
        if keyword.lower() in post["title"].lower():
            print(post["id"], "-", post["title"])
            found = True
        
    if not found:
        print("No posts found.")


def read_post():
    try:
        post_id = int(input("Enter post ID: "))
    except:
        print("Please enter valid number.")
        return
    
    for post in posts:
        if post["id"] == post_id:
            print("Title:", post["title"])
            print("Body:", post["body"])
            return
        
        print("Post not found.")


def save_post():
    try:
        post_id = int(input("Enetr post ID to save: "))
    except:
        print("Please enter a vaild number")
        return
    
    # new feature added here which is Prevent duplicate saves
    # Check if already saved
    for post in saved_posts:
        if post["id"] == post_id:
            print("Post alreday saved.")
            return

    # Find post in API data
    for post in posts:
        if post["id"] == post_id:
            saved_posts.append(post)
            print("Post saved!")
            return
        
    print("Post not found.")


def view_saved_posts():
    if not saved_posts:
        print("No saved post.")
        return
    
    for post in saved_posts:
        print(post["id"], "-", post["title"])


def saved_to_file():
    with open("saved_posts.json", "w") as file:
        json.dump(saved_posts, file)
    print("Saved to file!")


def load_saved_posts():
    global saved_posts
    try:
        with open("saved_posts.json", "r") as file:
            saved_posts = json.load(file)
    except:
        saved_posts = []


# new feature added here which is Delete saved posts
def delete_saved_post():
    try:
        post_id = int(input("Enter saved post ID to delete: "))
    except:
        print("Please enter a vaild number.")
        return
    
    for post in saved_posts:
        if post["id"] == post_id:
            saved_posts.remove(post)
            print("Post deleted successfully.")
            return
        
    print("Saved post not found")


# Updating Menu 
def show_menu():
    print("\n====== POST EXPLORER ======")
    print("1 Show first 10 posts")
    print("2 Search posts")
    print("3 Read post by ID")
    print("4 Save post")
    print("5 View saved posts")
    print("6 Delete saved post")
    print("7 Exit")


load_saved_posts()


# Updating Menu Logic too 
while True:
    show_menu()
    choice = input("Choose Option: ")

    if choice == "1":
        show_post()

    elif choice == "2":
        search_post()

    elif choice == "3":
        read_post()

    elif choice == "4":
        save_post()

    elif choice == "5":
        view_saved_posts()

    elif choice == "6":
        delete_saved_post()

    elif choice == "7":
        saved_to_file()
        print("Goodbye!")
        break

    else:
        print("Invaild Option")